# Bailian Coding Plan API Key (shared by Claude Code / Codex / OpenCode)
# Get your key at: https://bailian.console.aliyun.com/cn-beijing/?tab=model#/efm/coding_plan
BAILIAN_API_KEY=sk-your-key-here

# Host proxy port (Clash default: 7890, V2Ray default: 10808, ClashVerge default: 7897)
PROXY_PORT=7890

# Host SSH public key path (for SSH into container)
# Use your public key file, e.g. ~/.ssh/id_ed25519.pub or ~/.ssh/id_rsa.pub
SSH_AUTHORIZED_KEYS=~/.ssh/id_ed25519.pub
